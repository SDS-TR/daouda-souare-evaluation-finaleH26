# Copiez ces valeurs depuis Railway > MySQL > Connect > Public Network
# NE PAS utiliser mysql.railway.internal (réseau interne Railway seulement)

DB_HOST=thomas.proxy.rlwy.net
DB_USER=root
DB_PASSWORD=votre-mot-de-passe
DB_NAME=railway
DB_PORT=41790

# Option simple : collez l'URL complète depuis Railway (Public Network)
# MYSQL_PUBLIC_URL=mysql://root:mot-de-passe@thomas.proxy.rlwy.net:41790/railway

# Port du serveur Express EN LOCAL seulement
PORT=5000

# Sur Render : ne définissez PAS PORT (Render le fournit automatiquement)
